# =============================================================================
# BCCB Portfolio - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
# For production deployment, set these in Netlify Dashboard:
# Site Settings → Environment Variables

# =============================================================================
# Email Service (SendGrid)
# =============================================================================
# Your SendGrid API key (starts with SG.)
# Get it from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# The engineer's email address — contact form submissions are sent here
ENGINEER_EMAIL=your-email@example.com

# The "From" address for contact form emails (must be a verified SendGrid sender)
FROM_EMAIL=noreply@yourdomain.com

# =============================================================================
# Contact Form Rate Limiting
# =============================================================================
# Maximum number of contact form submissions per IP address per hour
# Recommended: 3 (allows legitimate users to correct mistakes)
RATE_LIMIT_MAX_PER_HOUR=3

# =============================================================================
# Site Configuration
# =============================================================================
# The public URL of your deployed site (used for CORS headers)
# Example: https://yourportfolio.netlify.app or https://yourname.dev
PUBLIC_SITE_URL=http://localhost:4321
