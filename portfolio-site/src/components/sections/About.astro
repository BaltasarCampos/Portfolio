---
/**
 * About.astro — Personal bio and skills section.
 * T037: Scroll-triggered entrance animations (portrait fades from left,
 *        bio text fades from right). Respects prefers-reduced-motion.
 */
---

<section id="about" class="about-section" aria-labelledby="about-heading">
  <div class="section about-inner">
    <div class="about-text about-animate-text">
      <h2 id="about-heading" class="section-heading">About Me</h2>

      <p class="about-bio">
        I'm a frontend engineer with a focus on building web experiences that are fast, accessible,
        and a pleasure to use. I care deeply about the craft — from semantic HTML and keyboard
        navigation to smooth animations that respect motion preferences.
      </p>
      <p class="about-bio">
        I've worked across the stack but feel most at home in the frontend, translating complex
        requirements into clean, maintainable code. I believe good software is invisible: it just
        works, for everyone.
      </p>
      <p class="about-bio">
        When I'm not writing TypeScript, I'm probably reading about compilers, experimenting with
        CSS, or contributing to open source.
      </p>

      <div class="about-skills-section" aria-label="Core technical skills">
        <h3 class="about-skills-heading">Core Skills</h3>
        <ul class="about-skills-list" role="list">
          {
            [
              'TypeScript / JavaScript',
              'React & React ecosystem',
              'Astro & SSG / SSR',
              'Tailwind CSS & CSS',
              'Accessibility (WCAG 2.1 AA)',
              'Performance optimisation',
              'Node.js & Edge Functions',
              'Testing (Vitest, Playwright)',
            ].map((skill) => (
              <li class="about-skill-item">{skill}</li>
            ))
          }
        </ul>
      </div>

      <a
        href="/cv.pdf"
        class="about-cv-link"
        download
        aria-label="Download CV as PDF"
      >
        <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 16l-4-4h3V4h2v8h3l-4 4zM4 18h16v2H4v-2z" fill="currentColor"/>
        </svg>
        Download CV
      </a>
    </div>
  </div>
</section>

<style>
  .about-section {
    padding-block: var(--section-padding-y);
  }

  .about-inner {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .about-text {
    max-width: 65ch;
  }

  .about-bio {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .about-skills-section {
    margin-top: 2rem;
  }

  .about-skills-heading {
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .about-skills-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.5rem;
  }

  .about-skill-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    color: var(--color-text);
    padding: 0.375rem 0;
  }

  .about-skill-item::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-primary);
    flex-shrink: 0;
  }

  .about-cv-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 2rem;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-primary);
    border: 2px solid var(--color-primary);
    transition:
      background-color var(--duration-base),
      color var(--duration-base);
    min-height: 48px;
  }

  .about-cv-link:hover {
    background-color: var(--color-primary);
    color: #fff;
  }

  /* T037 — scroll-triggered animation (JS adds .is-visible class) */
  @media (prefers-reduced-motion: no-preference) {
    .about-animate-text {
      opacity: 0;
      transform: translateX(2rem);
      transition:
        opacity 0.6s var(--easing-out),
        transform 0.6s var(--easing-out);
    }

    .about-animate-text.is-visible {
      opacity: 1;
      transform: translateX(0);
    }
  }
</style>

<!-- T037: IntersectionObserver adds .is-visible when section enters viewport -->
<script>
  const el = document.querySelector<HTMLElement>('.about-animate-text');
  if (el && typeof IntersectionObserver !== 'undefined') {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.15 },
    );
    observer.observe(el);
  }
</script>
