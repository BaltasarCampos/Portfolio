---
/**
 * Projects.astro — Static section wrapper that mounts the ProjectsGrid React island.
 */
import ProjectsGrid from './ProjectsGrid.tsx';
import { projects } from '../../data/projects.ts';
import { allTechnologies, allCategories, categoryLabels } from '../../data/technologies.ts';
---

<section id="projects" class="projects-section" aria-labelledby="projects-heading">
  <div class="section">
    <h2 id="projects-heading" class="section-heading">Projects</h2>
    <p class="section-subheading">
      A selection of work I'm proud of. Filter by technology or category.
    </p>

    <ProjectsGrid
      client:idle
      projects={projects}
      allTechnologies={allTechnologies}
      allCategories={allCategories}
      categoryLabels={categoryLabels}
    />
  </div>
</section>

<style>
  .projects-section {
    background-color: var(--color-bg-surface);
    padding-block: var(--section-padding-y);
  }
</style>
