---
/**
 * Navigation.astro — Fixed top nav bar with active section indicator.
 * Active state is driven by a client-side scroll observer injected inline.
 */
import { navItems } from '../../data/navigation.ts';
---

<header class="nav-header" role="banner">
  <nav class="nav-inner" aria-label="Main navigation">
    <!-- Logo / site name -->
    <a href="#hero" class="nav-logo" aria-label="Go to top — Baltasar Campos">
      <span aria-hidden="true">BC</span>
    </a>

    <!-- Navigation links -->
    <ul class="nav-list" role="list">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="nav-link"
              data-section={item.id}
              aria-current={item.id === 'hero' ? 'true' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<style>
  .nav-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    height: var(--nav-height);
    background: rgba(10, 10, 10, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    max-width: var(--content-max-width);
    margin-inline: auto;
    padding-inline: var(--section-padding-x);
  }

  .nav-logo {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.05em;
    transition: color var(--duration-base);
  }

  .nav-logo:hover {
    color: var(--color-text);
  }

  .nav-list {
    display: flex;
    gap: 0.25rem;
    align-items: center;
  }

  .nav-link {
    display: inline-block;
    padding: 0.5rem 0.875rem;
    border-radius: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition: color var(--duration-base), background-color var(--duration-base);
    position: relative;
  }

  .nav-link:hover {
    color: var(--color-text);
    background-color: rgba(255, 255, 255, 0.06);
  }

  .nav-link[aria-current='true'] {
    color: var(--color-text);
  }

  .nav-link[aria-current='true']::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0.875rem;
    right: 0.875rem;
    height: 2px;
    border-radius: 1px;
    background-color: var(--color-primary);
  }

  /* Mobile: hide labels, show only logo */
  @media (max-width: 639px) {
    .nav-link {
      padding: 0.5rem 0.5rem;
      font-size: 0.875rem;
    }
  }
</style>

<!-- Scroll-based active section detection + keyboard navigation (T023, T053) -->
<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-section]');
  const linkArray = [...links];
  const sectionIds = linkArray.map((l) => l.dataset['section'] as string);

  function setActive(id: string): void {
    links.forEach((link) => {
      const isActive = link.dataset['section'] === id;
      link.setAttribute('aria-current', isActive ? 'true' : 'false');
    });
  }

  // IntersectionObserver — fires when section enters/leaves viewport
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          setActive(entry.target.id);
        }
      }
    },
    { rootMargin: '-50% 0px -50% 0px' },
  );

  // Observe each section
  sectionIds.forEach((id) => {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });

  // T053 — Arrow key navigation between nav links
  links.forEach((link, index) => {
    link.addEventListener('keydown', (e: KeyboardEvent) => {
      let next: HTMLAnchorElement | undefined;

      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
        e.preventDefault();
        next = linkArray[index + 1] ?? linkArray[0];
      } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
        e.preventDefault();
        next = linkArray[index - 1] ?? linkArray[linkArray.length - 1];
      } else if (e.key === 'Home') {
        e.preventDefault();
        next = linkArray[0];
      } else if (e.key === 'End') {
        e.preventDefault();
        next = linkArray[linkArray.length - 1];
      }

      next?.focus();
    });
  });
</script>
